# ── Supabase (project ref: cquqhtbqiklcjarlauek) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://cquqhtbqiklcjarlauek.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"
# Settings → API → service_role (server only — never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="media"

AUTH_SECRET="your-secret"
ADMIN_PASSWORD="admin123"

# Local dev preview URL (Vercel auto-detects VERCEL_URL in production)
NEXT_PUBLIC_WEB_URL="http://localhost:3000/web"
# NEXT_PUBLIC_SITE_URL="https://your-custom-domain.com"

# Preview content synced on save (default: apps/admin/content)
# WEB_CONTENT_DIR="content"

# Local upload fallback when Supabase keys are not set (optional)
# UPLOAD_DIR="public/uploads"

# Static build export target (default: apps/web/content)
# STATIC_CONTENT_DIR="../../apps/web/content"

# AI Page Builder
OPENAI_API_KEY=""

# Sales Assistant chat (same origin — /api/assistant/chat)
ASSISTANT_AI_MODEL="meta/llama-3.1-8b-instruct"
