# Database (Prisma Postgres / Vercel — pull with: vercel env pull)
DATABASE_URL="postgresql://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

AUTH_SECRET="your-secret"
ADMIN_PASSWORD="admin123"
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Paths (relative to apps/admin)
WEB_CONTENT_DIR="../../apps/web/content"
UPLOAD_DIR="../../apps/web/public/uploads"

# AI Page Builder
# OpenAI: use sk-... key (defaults to api.openai.com + gpt-4o-mini)
# NVIDIA: use nvapi-... key (auto-detects integrate.api.nvidia.com)
OPENAI_API_KEY=""
# AI_API_BASE_URL="https://integrate.api.nvidia.com/v1"
# AI_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
# AI_TEMPERATURE="1"
# AI_TOP_P="0.95"
# AI_MAX_TOKENS="16384"
# AI_REASONING_BUDGET="16384"
# AI_ENABLE_THINKING="true"

# Sales Assistant chat (separate from page builder — uses ASSISTANT_AI_MODEL only)
# ASSISTANT_CORS_ORIGIN="http://localhost:3000"
ASSISTANT_AI_MODEL="meta/llama-3.1-8b-instruct"
