{
  "name": "cms",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@cms/web",
    "dev:all": "npm run dev:admin & npm run dev:web",
    "dev:admin": "npm run dev --workspace=@cms/admin",
    "dev:web": "npm run dev --workspace=@cms/web",
    "build": "npm run build --workspace=@cms/web",
    "build:admin": "npm run build --workspace=@cms/admin",
    "serve": "npm run serve --workspace=@cms/web",
    "db:generate": "npm run db:generate --workspace=@cms/db",
    "db:push": "npm run db:push --workspace=@cms/db",
    "db:seed": "npm run db:seed --workspace=@cms/db",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
